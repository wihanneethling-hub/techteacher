---
import BaseLayout from "../layouts/BaseLayout.astro";

const journey = [
  {
    chapter: "Head of Education",
    dates: "2025-Present",
    body:
      "At Digicape, Wihan leads education strategy, professional learning, school partnerships, AI in education and change management support for schools."
  },
  {
    chapter: "Business & Strategy",
    dates: "2024-2025",
    body:
      "As Engagement Lead at Proco, Wihan worked across partnerships, school procurement, tender management, contracts and stakeholder engagement."
  },
  {
    chapter: "Apple Professional Learning",
    dates: "2018-2024",
    body:
      "As a former Apple Professional Learning Specialist, Wihan supported teacher development through workshops, coaching and practical guidance for schools implementing 1:1 iPad learning initiatives."
  },
  {
    chapter: "Classroom & School Leadership",
    dates: "2016-2024",
    body:
      "At Rustenburg Girls' High School, Wihan moved from teacher to Technology Integration Specialist, Head of Technology Integration and Head of Innovation, supporting teaching practice, staff development and school-wide digital strategy."
  },
  {
    chapter: "Professional Rugby",
    dates: "2003-2009",
    body:
      "A high-performance environment that shaped Wihan's approach to teamwork, leadership, resilience and preparation."
  }
];

const schoolSupport = [
  "Developing a clear vision for learning",
  "Leading meaningful change",
  "Building teacher confidence",
  "Professional learning and coaching",
  "Artificial intelligence in education",
  "Digital strategy and technology planning",
  "Apple ecosystem adoption",
  "School leadership and stakeholder engagement",
  "Procurement, governance and sustainable implementation"
];

const highlights = [
  "Head of Education at Digicape",
  "Former Head of Innovation at Rustenburg Girls' High School",
  "Former Apple Professional Learning Specialist",
  "Trained and supported hundreds of educators",
  "Contributed to the planning and adoption of multiple 1:1 iPad programmes",
  "Experience across education, business, leadership and professional sport"
];
---

<BaseLayout
  title="Profile"
  description="Professional profile for Wihan Neethling, an education leader helping schools make better decisions about technology, leadership and change."
>
  <section class="profile-hero">
    <div class="container profile-hero-grid">
      <div class="profile-hero-copy">
        <p class="eyebrow">Profile</p>
        <h1>Wihan Neethling</h1>
        <p class="profile-subtitle">
          Education Leader | Professional Learning Facilitator | Strategic Advisor
        </p>
        <p class="profile-positioning">
          Helping schools make better decisions about technology, leadership and change.
        </p>
        <p>
          I work with schools, leadership teams and educators to make technology decisions that are practical, purposeful and grounded in good teaching.
        </p>
      </div>
      <aside class="profile-quote-card" aria-label="Profile headshot and quote">
        <figure class="profile-quote-image">
          <img src="/images/wihan-profile-professional.png" alt="Wihan Neethling" />
        </figure>
        <blockquote>
          “Technology should support great teaching, not drive it.”
        </blockquote>
      </aside>
    </div>
  </section>

  <section class="section container profile-page">
    <section class="profile-section">
      <div class="section-header compact">
        <div>
          <p class="eyebrow">Professional Summary</p>
          <h2>Education, technology and change</h2>
        </div>
      </div>
      <div class="profile-prose">
        <p>
          Wihan is Head of Education at Digicape, where he works with schools on education strategy, professional learning, digital transformation and meaningful technology adoption.
        </p>
        <p>
          His experience spans classroom teaching, school leadership, professional learning, business development, school strategy and stakeholder engagement. He is a former school leader at Rustenburg Girls' High School, a former Apple Professional Learning Specialist and a former professional rugby player.
        </p>
        <p>
          This mix of education, business and high-performance sport shapes how he supports schools: with a focus on people, clear decision-making, practical implementation and long-term change.
        </p>
      </div>
    </section>

    <section class="profile-philosophy">
      <div>
        <p class="eyebrow">My Philosophy</p>
        <h2>Technology should support great teaching, not drive it.</h2>
      </div>
      <div class="profile-prose">
        <p>
          Pedagogy, people and purpose should come before technology. Devices, platforms and artificial intelligence tools can be powerful, but only when they serve a clear educational purpose.
        </p>
        <p>
          Schools often struggle less with technology itself and more with vision, priorities, leadership and change. Good technology decisions should improve learning, build teacher confidence and create more coherent experiences for students.
        </p>
        <p>
          My role is to help schools make confident, informed decisions that are aligned to their educational goals rather than simply adding more devices, apps or platforms.
        </p>
      </div>
    </section>

    <section class="profile-section">
      <div class="section-header compact">
        <div>
          <p class="eyebrow">Career Journey</p>
          <h2>Five chapters that shape the work</h2>
        </div>
      </div>
      <div class="experience-timeline">
        {
          journey.map((item) => (
            <article class="experience-card">
              <div class="experience-date">{item.dates}</div>
              <div>
                <h3>{item.chapter}</h3>
                <p>{item.body}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="profile-section profile-panel profile-help">
      <div class="section-header compact">
        <div>
          <p class="eyebrow">What I Help Schools With</p>
          <h2>Practical support for better decisions</h2>
        </div>
      </div>
      <ul class="expertise-list profile-help-list">
        {schoolSupport.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="profile-section">
      <div class="section-header compact">
        <div>
          <p class="eyebrow">Selected Highlights</p>
          <h2>Selected Highlights</h2>
        </div>
      </div>
      <ul class="highlight-grid profile-highlight-list">
        {highlights.map((item) => <li>{item}</li>)}
      </ul>
    </section>

    <section class="profile-section profile-closing">
      <p class="eyebrow">Writing</p>
      <h2>Read my latest writing on education, technology and leadership.</h2>
      <a class="button" href="/blog/">Visit the blog</a>
    </section>
  </section>
</BaseLayout>
