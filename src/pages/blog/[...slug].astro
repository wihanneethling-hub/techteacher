---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { getCategoryUrl, getPostSlug, getPostUrl, getTagUrl } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post }
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const postUrl = getPostUrl(post);
const postImage = post.data.image ?? "/assets/tech-teacher-logo-wide.png";
const wordCount = (post.body ?? "").trim().split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 220));
const relatedPosts = allPosts
  .filter((candidate) => candidate.id !== post.id)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => post.data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === post.data.category ? 3 : 0;
    return { post: candidate, score: sharedTags + categoryMatch };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score || b.post.data.date.valueOf() - a.post.data.date.valueOf())
  .slice(0, 3)
  .map(({ post }) => post);
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  image: new URL(postImage, Astro.site).toString(),
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  author: {
    "@type": "Person",
    name: "Wihan Neethling",
    url: new URL("/profile/", Astro.site).toString()
  },
  publisher: {
    "@type": "Organization",
    name: "The Tech Teacher",
    logo: {
      "@type": "ImageObject",
      url: new URL("/assets/tech-teacher-avatar.png", Astro.site).toString()
    }
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(postUrl, Astro.site).toString()
  },
  articleSection: post.data.category,
  keywords: post.data.tags.join(", ")
};
---

<BaseLayout title={post.data.title} description={post.data.description} image={postImage} canonical={postUrl} ogType="article">
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    <meta property="article:section" content={post.data.category} />
    {post.data.tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>
  <article class="article">
    <header>
      <p class="eyebrow">Blog post</p>
      <h1>{post.data.title}</h1>
      <div class="post-meta" style="margin-top:18px;">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString("en-ZA", { year: "numeric", month: "long", day: "numeric" })}
        </time>
        <a href={getCategoryUrl(post.data.category)}>{post.data.category}</a>
        <span>{readingTime} min read</span>
        {post.data.originalUrl && <a href={post.data.originalUrl}>Original Blogger post</a>}
      </div>
      <ul class="tag-list">
        {post.data.tags.map((tag) => <li><a class="tag" href={getTagUrl(tag)}>{tag}</a></li>)}
      </ul>
      {post.data.image && (
        <figure class="article-hero-image">
          <img src={post.data.image} alt="" loading="eager" decoding="async" />
        </figure>
      )}
    </header>
    <div class="article-body">
      <Content />
    </div>
    <aside class="author-card" aria-labelledby="author-card-title">
      <img src="/images/wihan-profile-professional.png" alt="Wihan Neethling" width="88" height="88" />
      <div>
        <p class="eyebrow">Written by</p>
        <h2 id="author-card-title">Wihan Neethling</h2>
        <p>
          Education leader, professional learning facilitator, strategic advisor, and author of The Tech Teacher.
        </p>
        <a href="/profile/">View profile</a>
      </div>
    </aside>
  </article>
  {relatedPosts.length > 0 && (
    <section class="section container related-posts" aria-labelledby="related-posts-title">
      <div class="section-header">
        <div>
          <p class="eyebrow">Keep reading</p>
          <h2 id="related-posts-title">Related articles</h2>
        </div>
      </div>
      <div class="post-grid">
        {relatedPosts.map((relatedPost) => <PostCard post={relatedPost} />)}
      </div>
    </section>
  )}
</BaseLayout>
